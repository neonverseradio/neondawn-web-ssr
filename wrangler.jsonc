{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neondawn-web-ssr",
  "compatibility_date": "2026-07-22",
  "observability": {
    "enabled": true
  },
  "main": "./workers/app.ts",
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}